@начало
// Пример с русскими ключевыми словами

// Если есть монета - идем вперед
если({} монета) {
    вперед 1;
} иначе {
    вперед 5;
};

// Пока пусто - идем
пока({} пусто) {
    вперед 1;
};

// Цикл for - поворот 3 раза
для(3 раз) {
    вправо 90;
};

// Базовые действия
вперед 5;
назад 2;
вправо 90;
влево 45;

@конец
